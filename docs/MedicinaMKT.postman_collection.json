{
  "info": {
    "name": "MedicinaMKT — API de Integração",
    "description": "Coleção para integração de IA (n8n, Make, scripts próprios) com a plataforma MedicinaMKT. Não inclui endpoints de super ADM. Ver docs completas em docs/API.md.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "Authorization", "type": "string" },
      { "key": "value", "value": "Bearer {{anon_key}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url",   "value": "https://pllvpbzskmargpdpvumg.supabase.co", "type": "string" },
    { "key": "anon_key",   "value": "COLE_SUA_ANON_KEY_AQUI", "type": "string" },
    { "key": "instancia",  "value": "clinicaolhos", "type": "string" },
    { "key": "evolution_url", "value": "https://evolutionapi.nexladesenvolvimento.com.br", "type": "string" }
  ],
  "item": [
    {
      "name": "Pacientes",
      "description": "CRUD da tabela `saved_contacts` — pacientes cadastrados.",
      "item": [
        {
          "name": "Listar pacientes",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{anon_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/rest/v1/saved_contacts?instancia=eq.{{instancia}}&order=nome.asc&limit=100",
              "host": ["{{base_url}}"],
              "path": ["rest", "v1", "saved_contacts"],
              "query": [
                { "key": "instancia", "value": "eq.{{instancia}}" },
                { "key": "order", "value": "nome.asc" },
                { "key": "limit", "value": "100" }
              ]
            }
          }
        },
        {
          "name": "Buscar paciente por número",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{anon_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/rest/v1/saved_contacts?instancia=eq.{{instancia}}&numero=eq.5511987654321@s.whatsapp.net&select=*&limit=1",
              "host": ["{{base_url}}"],
              "path": ["rest", "v1", "saved_contacts"],
              "query": [
                { "key": "instancia", "value": "eq.{{instancia}}" },
                { "key": "numero", "value": "eq.5511987654321@s.whatsapp.net" },
                { "key": "select", "value": "*" },
                { "key": "limit", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Buscar por nome (parcial)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{anon_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/rest/v1/saved_contacts?instancia=eq.{{instancia}}&nome=ilike.*maria*&limit=10",
              "host": ["{{base_url}}"],
              "path": ["rest", "v1", "saved_contacts"],
              "query": [
                { "key": "instancia", "value": "eq.{{instancia}}" },
                { "key": "nome", "value": "ilike.*maria*" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Criar paciente",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{anon_key}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Prefer", "value": "return=representation" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"instancia\": \"{{instancia}}\",\n  \"nome\": \"Maria Silva\",\n  \"numero\": \"5511987654321@s.whatsapp.net\",\n  \"birthdate\": \"1985-03-15\",\n  \"gender\": \"feminino\",\n  \"email\": \"maria@email.com\",\n  \"insurance_plan_id\": null,\n  \"card_number\": null,\n  \"allergies\": \"Penicilina\",\n  \"chronic_conditions\": null,\n  \"medications\": null,\n  \"origem\": \"Instagram\",\n  \"primeiro_contato\": \"sim\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/rest/v1/saved_contacts",
              "host": ["{{base_url}}"],
              "path": ["rest", "v1", "saved_contacts"]
            }
          }
        },
        {
          "name": "Atualizar paciente",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "apikey", "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{anon_key}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Prefer", "value": "return=representation" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"allergies\": \"Penicilina, dipirona\",\n  \"chronic_conditions\": \"Hipertensão\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/rest/v1/saved_contacts?id=eq.PACIENTE_ID",
              "host": ["{{base_url}}"],
              "path": ["rest", "v1", "saved_contacts"],
              "query": [{ "key": "id", "value": "eq.PACIENTE_ID" }]
            }
          }
        },
        {
          "name": "Deletar paciente",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "apikey", "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{anon_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/rest/v1/saved_contacts?id=eq.PACIENTE_ID",
              "host": ["{{base_url}}"],
              "path": ["rest", "v1", "saved_contacts"],
              "query": [{ "key": "id", "value": "eq.PACIENTE_ID" }]
            }
          }
        }
      ]
    },
